# Environment Configuration Example
# Copy this as .env and fill in your actual values

# ============ GEMINI API ============
GEMINI_API_KEY=your_gemini_api_key_here

# ============ RAZORPAY ============
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_SECRET=your_razorpay_secret

# ============ DATABASE ============
DB_URL=mongodb+srv://username:password@cluster.mongodb.net/recyclehub

# ============ JWT ============
JWT_SECRET=your_very_secure_jwt_secret_key

# ============ EMAIL ============
MAIL_USER=your_email@gmail.com
MAIL_PASS=your_app_specific_password

# ============ GOOGLE OAUTH ============
GOOGLE_CLIENT_ID=your_google_client_id

# ============ FRONTEND URLs ============
FRONTEND_URL=https://your-production-frontend-url.vercel.app
FRONTEND_DEV_URL=http://localhost:5173

# ============ SERVER PORT ============
PORT=5000
